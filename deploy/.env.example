# Скопируйте в .env рядом с deploy/docker-compose.yml:
#   cp .env.example .env

# --- Docker Hub (обязательно) — https://hub.docker.com/u/lapiki ---
DOCKERHUB_USER=lapiki

# Тег образов (по умолчанию latest)
IMAGE_TAG=latest

# Префикс имён контейнеров на хосте
CONTAINER_PREFIX=postgen

# Имя Docker-сети (bridge)
NETWORK_NAME=postgen_app_net

# Порты на сервере
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=80

# Nginx → API: в одном docker compose достаточно имени сервиса «backend».
# В Dokploy часто фронт и API в разных стеках — имя «backend» в DNS нет → 502 «could not be resolved».
# Вариант A — внутренний HTTP (если известно имя сервиса в сети):
# BACKEND_URL=http://post-generator-backend-XXXX:8000
# Вариант B — публичный HTTPS бэкенда в Traefik (когда внутренний DNS недоступен):
# BACKEND_URL=https://post-generator-backend-XXXX.traefik.me
# BACKEND_HOST=backend
# BACKEND_PORT=8000
# NGINX_RESOLVER=127.0.0.11

# --- Переменные приложения (backend читает из env) ---
BASE_URL=https://api.proxyapi.ru/openai/v1
API_KEY=your-proxyapi-key
MODEL=gpt-4o-mini
LLM_TIMEOUT=360

# Опционально
# ANALYZE_MAX_TEXT_CHARS=80000
# ANALYZE_FETCH_TIMEOUT=30
