# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# OpenAI-совместимый endpoint (должен заканчиваться на .../v1).
# ProxyAPI (OpenAI): https://api.proxyapi.ru/openai/v1 — см. https://proxyapi.ru/docs/overview
BASE_URL=https://api.proxyapi.ru/openai/v1

# Ключ для заголовка Authorization: Bearer ...
API_KEY=your-api-key-here

# Модель (список — в документации ProxyAPI / OpenAI)
MODEL=gpt-4o-mini

# Таймаут HTTP-запроса к LLM (секунды). При «Request timed out» увеличьте, например 180 или 300.
LLM_TIMEOUT=120
